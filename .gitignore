# =============================================
# C200 Controller — .gitignore
# =============================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Xcode
*.xcworkspace
*.xcuserdata/
xcuserdata/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
build/

# Firmware bin copied into the macOS app bundle at build time —
# regenerated by C200Controller's preBuildScript from
# ESP32Flasher/FirmwareTemplate/build/c200_bridge.bin.
C200Controller/Resources/Generated/c200_bridge.bin

# Swift Package Manager
.build/
.swiftpm/
# Note: Package.resolved is committed to pin dependency versions

# Claude Code team scripts (local dev only)
.claude/
Open\ Claude.command
start-claude-team.sh

# ESP32Flasher GUI app — separate project, not tracked here.
# Firmware source IS tracked. Git can't re-include a child of an ignored
# directory by negation, so the un-ignore pattern needs `**` to match
# everything inside the firmware tree.
ESP32Flasher/*
!ESP32Flasher/FirmwareTemplate
!ESP32Flasher/FirmwareTemplate/**

# Firmware build artifacts + local-only credentials inside the tracked firmware tree
ESP32Flasher/FirmwareTemplate/build/
ESP32Flasher/FirmwareTemplate/.cache/
ESP32Flasher/FirmwareTemplate/managed_components/
ESP32Flasher/FirmwareTemplate/dependencies.lock
ESP32Flasher/FirmwareTemplate/sdkconfig.old
ESP32Flasher/FirmwareTemplate/main/wifi_config.h

# Large binary files (datasheets, etc.)
*.pdf

# Node / companion-module
companion-module/node_modules/
companion-module/.npmrc

# Environment / secrets
.env
*.env
secrets/

# Log files (local debug only)
*.log
c200_debug.log

# Archives (never commit release zips to tree)
*.zip
*.dmg

# Editors
.vscode/settings.json
.idea/
*.swp
*.swo

# OneDrive metadata
desktop.ini
